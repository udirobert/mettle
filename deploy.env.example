# Set these in Coolify. Never commit a real production environment file.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Use a URL-safe generated value (letters and digits only) for this password.
POSTGRES_PASSWORD=

# Comma-separated browser origins. Include the Vercel production hostname and
# any approved preview host used for the client demo.
CORS_ALLOWED_ORIGINS=https://mettle.vercel.app
